# API exposure
API_PORT=8000

# Solver/API runtime
SOLVER_REQUEST_TIMEOUT=30
HIGHS_THREADS=4
OMP_NUM_THREADS=4
CPLEX_SOLVER_URL=

# Leave empty when DB is not used.
DATABASE_URL=
# When using the bundled postgres profile, use:
# DATABASE_URL=postgresql://dsopt:dsopt123@postgres:5432/ds_opt_app
DATABASE_URL=postgresql://dsopt:dsopt123@postgres:5432/ds_opt_app
POSTGRES_DB=ds_opt_app
POSTGRES_USER=dsopt
POSTGRES_PASSWORD=dsopt123
POSTGRES_HOST=postgres

# Optional bundled postgres profile
POSTGRES_PORT=5432
POSTGRES_DB=ds_opt_app
POSTGRES_USER=dsopt
POSTGRES_PASSWORD=dsopt123
