{
  "info": {
    "name": "PuLP Solver API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Healthz",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/healthz",
          "host": ["{{baseUrl}}"],
          "path": ["healthz"]
        }
      }
    },
    {
      "name": "Solve",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sense\": \"min\",\n  \"objective\": [2, 3],\n  \"constraints\": [\n    {\"coeffs\": [1, 2], \"sense\": \">=\", \"rhs\": 8},\n    {\"coeffs\": [3, 1], \"sense\": \">=\", \"rhs\": 9}\n  ],\n  \"var_bounds\": [\n    {\"low\": 0, \"up\": 10},\n    {\"low\": 0}\n  ],\n  \"var_cats\": [\"Binary\", \"Continuous\"],\n  \"solver\": \"HiGHS\",\n  \"problem_type\": \"MILP\",\n  \"time_limit_sec\": 10\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/solve",
          "host": ["{{baseUrl}}"],
          "path": ["solve"]
        }
      }
    },
    {
      "name": "Get Job",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/jobs/{{request_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["jobs", "{{request_id}}"]
        }
      }
    },
    {
      "name": "Delete Job",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/jobs/{{request_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["jobs", "{{request_id}}"]
        }
      }
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8000"},
    {"key": "request_id", "value": "your-request-id"}
  ]
}
